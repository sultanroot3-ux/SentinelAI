# Copy to `.env` next to docker-compose.yml and fill in real values.
# docker compose refuses to start without them.
# (deployment/install_ubuntu.sh generates this file automatically.)

# JWT signing key — generate with: openssl rand -hex 32
SENTINEL_SECRET_KEY=

# PostgreSQL password for the `sentinel` database user
SENTINEL_DB_PASSWORD=

# ---- production (docker-compose.prod.yml) ----

# Public domain the dashboard is served on (Let's Encrypt certificate name)
DOMAIN=

# Uvicorn worker processes. Each live MJPEG stream occupies a worker thread;
# raise this with camera count (2 is fine for a single webcam deployment).
UVICORN_WORKERS=2

# Days of daily pg_dump backups to keep in ./backups
BACKUP_RETENTION_DAYS=14

# Proxies whose X-Forwarded-For is trusted for client-IP resolution (rate
# limiting). JSON list of IPs/CIDRs. Default covers the Docker compose network
# so nginx's forwarded client IPs are honored. Leave unset outside Docker.
#SENTINEL_TRUSTED_PROXY_IPS=["172.16.0.0/12"]
